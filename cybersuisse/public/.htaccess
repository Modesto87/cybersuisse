# Configuration Apache Simplifiée pour React SPA
# Si vous avez une erreur 500, essayez de commenter les blocs <IfModule> un par un

# 1. Redirection SPA (Essentiel pour React)
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
    
    # Ne pas rediriger les fichiers existants
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]
    
    # Rediriger tout le reste vers index.html
    RewriteRule ^index\.html$ - [L]
    RewriteRule . /index.html [L]
</IfModule>

# 2. Headers de sécurité de base (Optionnel - commenter si erreur)
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
</IfModule>

# 3. Compression (Optionnel)
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css application/javascript
</IfModule>
